# Bot Discord — https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Application ID (onglet « General Information » du portail développeur)
DISCORD_CLIENT_ID=
# ID du serveur Vision+ (clic droit sur le serveur → Copier l'identifiant)
DISCORD_GUILD_ID=

# Site Vision+ (mêmes valeurs que sitewebvision)
SITE_URL=https://vision-plus.tech
DISCORD_INVITE_URL=https://discord.gg/83N75v6VRh

# Supabase (même projet que sitewebvision — clé service role)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# XP — valeurs par défaut si omis
# XP_MESSAGE=1
# XP_REACTION=0.5
# XP_VOICE_PER_MINUTE=1
# MESSAGE_COOLDOWN_SECONDS=60
# REACTION_COOLDOWN_SECONDS=30
# MIN_MESSAGE_LENGTH=3

# Salons vocaux AFK à ignorer (IDs séparés par des virgules)
# AFK_CHANNEL_IDS=

# Rôles Discord staff — obligatoire pour /quiz activer et /quiz desactiver
